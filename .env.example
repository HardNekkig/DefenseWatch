# DefenseWatch environment variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically on startup.

# Webhook notifications (Slack, Discord, etc.)
DEFENSEWATCH_WEBHOOK_URL=

# Scheduled report delivery webhook
DEFENSEWATCH_REPORTS_WEBHOOK_URL=

# External enrichment API keys
DEFENSEWATCH_SHODAN_API_KEY=
DEFENSEWATCH_VIRUSTOTAL_API_KEY=
DEFENSEWATCH_CENSYS_API_ID=
DEFENSEWATCH_CENSYS_API_SECRET=

# Threat intelligence feeds
DEFENSEWATCH_ABUSEIPDB_API_KEY=
DEFENSEWATCH_OTX_API_KEY=

# CORS origin (default: *)
DEFENSEWATCH_CORS_ORIGIN=*

# Log format: "json" for structured JSON, anything else for plain text
DEFENSEWATCH_LOG_FORMAT=

# Telegram bot
DEFENSEWATCH_TELEGRAM_BOT_TOKEN=
DEFENSEWATCH_TELEGRAM_CHAT_IDS=